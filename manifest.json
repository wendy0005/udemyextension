{
  "manifest_version": 3,
  "name": "Udemy Transcript Helper",
  "version": "0.1.0",
  "description": "Content script helpers for learning from Udemy transcripts.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Udemy Transcript Helper"
  },
  "host_permissions": [
    "https://www.udemy.com/*",
    "https://cognizant.udemy.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.udemy.com/*",
        "https://cognizant.udemy.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
